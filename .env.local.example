# Copy this file to .env.local and fill in the values (all from your buddy's accounts).

# --- Supabase (Project Settings > API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Resend (resend.com > API Keys). The FROM domain must be verified in Resend. ---
RESEND_API_KEY=re_your_key
EMAIL_FROM=TonTon Trailer Rentals <storage@thetrailerteam.com>
# Where provider (Anton) notifications go:
PROVIDER_EMAIL=storage@thetrailerteam.com

# --- App URL (used in emails + links). Locally use http://localhost:3500 ---
APP_URL=http://localhost:3500

# --- Cron protection. Vercel sends this automatically when set in project env. ---
CRON_SECRET=make-up-a-long-random-string

# --- Simple admin gate (optional for the rough draft) ---
ADMIN_PASSWORD=changeme
